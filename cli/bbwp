#!/usr/bin/env python3

import argparse
import shutil
import sys
from pathlib import Path


PROJECT_ROOT = Path(__file__).resolve().parent.parent
WORDLIST_ROOT = PROJECT_ROOT / "wordlists"
VERSION_FILE = PROJECT_ROOT / "VERSION.txt"


def get_wordlists() -> list[Path]:
    return sorted(WORDLIST_ROOT.rglob("*.txt"))


def relative_name(path: Path) -> str:
    return str(path.relative_to(WORDLIST_ROOT))


def command_stats(_: argparse.Namespace) -> int:
    files = get_wordlists()
    total_entries = 0

    print("Bug Bounty Wordlists Pro")
    print("========================")

    for file in files:
        entries = read_entries(file)
        total_entries += len(entries)
        print(f"{relative_name(file):45} {len(entries):6} entries")

    version = VERSION_FILE.read_text(encoding="utf-8").strip()

    print("========================")
    print(f"Version:       {version}")
    print(f"Wordlists:     {len(files)}")
    print(f"Total entries: {total_entries}")

    return 0


def command_list(_: argparse.Namespace) -> int:
    for file in get_wordlists():
        print(relative_name(file))

    return 0


def command_search(args: argparse.Namespace) -> int:
    keyword = args.keyword
    matches: list[tuple[str, str]] = []

    for file in get_wordlists():
        for entry in read_entries(file):
            if keyword.lower() in entry.lower():
                matches.append((relative_name(file), entry))

    if not matches:
        print(f"No entries found for: {keyword}", file=sys.stderr)
        return 1

    for filename, entry in matches:
        print(f"{filename}: {entry}")

    print(f"\nMatches: {len(matches)}")
    return 0


def resolve_wordlist(name: str) -> Path | None:
    requested = name.removesuffix(".txt")

    exact_matches = []
    partial_matches = []

    for file in get_wordlists():
        relative = relative_name(file)
        relative_without_extension = relative.removesuffix(".txt")

        if requested == relative_without_extension:
            exact_matches.append(file)
        elif requested.lower() in relative_without_extension.lower():
            partial_matches.append(file)

    if len(exact_matches) == 1:
        return exact_matches[0]

    if len(partial_matches) == 1:
        return partial_matches[0]

    if len(partial_matches) > 1:
        print("Multiple matching wordlists:", file=sys.stderr)
        for file in partial_matches:
            print(f"  {relative_name(file)}", file=sys.stderr)

    return None


def command_show(args: argparse.Namespace) -> int:
    file = resolve_wordlist(args.wordlist)

    if file is None:
        print(f"Wordlist not found or ambiguous: {args.wordlist}", file=sys.stderr)
        return 1

    print(file.read_text(encoding="utf-8"), end="")
    return 0


def command_export(args: argparse.Namespace) -> int:
    source = resolve_wordlist(args.wordlist)

    if source is None:
        print(f"Wordlist not found or ambiguous: {args.wordlist}", file=sys.stderr)
        return 1

    destination = Path(args.output).expanduser().resolve()
    destination.parent.mkdir(parents=True, exist_ok=True)

    shutil.copyfile(source, destination)

    print(f"Exported: {relative_name(source)}")
    print(f"Output:   {destination}")
    return 0


def read_entries(file: Path) -> list[str]:
    return [
        line.strip()
        for line in file.read_text(encoding="utf-8").splitlines()
        if line.strip()
    ]



def command_doctor(_: argparse.Namespace) -> int:
    print("Bug Bounty Wordlists Pro Doctor")
    print("===============================")

    errors: list[str] = []
    warnings: list[str] = []

    if PROJECT_ROOT.is_dir():
        print(f"[OK] Project root: {PROJECT_ROOT}")
    else:
        errors.append(f"Project root is missing: {PROJECT_ROOT}")

    if VERSION_FILE.is_file():
        version = VERSION_FILE.read_text(encoding="utf-8").strip()

        if version:
            print(f"[OK] Version file: {version}")
        else:
            errors.append("VERSION.txt is empty")
    else:
        errors.append(f"Version file is missing: {VERSION_FILE}")

    if WORDLIST_ROOT.is_dir():
        print(f"[OK] Wordlist directory: {WORDLIST_ROOT}")
    else:
        errors.append(f"Wordlist directory is missing: {WORDLIST_ROOT}")

    cli_file = Path(__file__).resolve()

    if cli_file.stat().st_mode & 0o111:
        print("[OK] CLI file is executable")
    else:
        warnings.append(f"CLI file is not executable: {cli_file}")

    files = get_wordlists() if WORDLIST_ROOT.is_dir() else []

    if files:
        print(f"[OK] Wordlist files: {len(files)}")
    else:
        errors.append("No wordlist files were found")

    total_entries = 0
    empty_files: list[str] = []
    duplicate_files: list[tuple[str, int]] = []
    formatting_files: list[tuple[str, int]] = []

    for file in files:
        raw_lines = file.read_text(encoding="utf-8").splitlines()
        entries = [line.strip() for line in raw_lines if line.strip()]

        total_entries += len(entries)

        if not entries:
            empty_files.append(relative_name(file))

        duplicate_count = len(entries) - len(set(entries))

        if duplicate_count:
            duplicate_files.append(
                (relative_name(file), duplicate_count)
            )

        formatting_count = sum(
            1
            for line in raw_lines
            if not line.strip() or line != line.strip()
        )

        if formatting_count:
            formatting_files.append(
                (relative_name(file), formatting_count)
            )

    if total_entries:
        print(f"[OK] Total entries: {total_entries}")

    if empty_files:
        for filename in empty_files:
            errors.append(f"Empty wordlist: {filename}")
    else:
        print("[OK] No empty wordlists")

    if duplicate_files:
        for filename, count in duplicate_files:
            errors.append(
                f"Duplicate entries: {filename} ({count})"
            )
    else:
        print("[OK] No duplicate entries")

    if formatting_files:
        for filename, count in formatting_files:
            warnings.append(
                f"Blank or untrimmed lines: {filename} ({count})"
            )
    else:
        print("[OK] Wordlist formatting")

    print("===============================")

    for warning in warnings:
        print(f"[WARN] {warning}")

    for error in errors:
        print(f"[ERROR] {error}", file=sys.stderr)

    if errors:
        print(f"Status: unhealthy ({len(errors)} errors)")
        return 1

    if warnings:
        print(f"Status: healthy with {len(warnings)} warnings")
        return 0

    print("Status: healthy")
    return 0

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="bbwp",
        description="Search and manage Bug Bounty Wordlists Pro.",
    )

    subparsers = parser.add_subparsers(dest="command", required=True)

    stats_parser = subparsers.add_parser(
        "stats",
        help="Display package statistics.",
    )
    stats_parser.set_defaults(function=command_stats)

    list_parser = subparsers.add_parser(
        "list",
        help="List available wordlists.",
    )
    list_parser.set_defaults(function=command_list)

    search_parser = subparsers.add_parser(
        "search",
        help="Search all wordlists.",
    )
    search_parser.add_argument("keyword")
    search_parser.set_defaults(function=command_search)

    show_parser = subparsers.add_parser(
        "show",
        help="Print one wordlist.",
    )
    show_parser.add_argument("wordlist")
    show_parser.set_defaults(function=command_show)

    export_parser = subparsers.add_parser(
        "export",
        help="Export one wordlist to another location.",
    )
    export_parser.add_argument("wordlist")
    export_parser.add_argument("-o", "--output", required=True)
    export_parser.set_defaults(function=command_export)
    doctor_parser = subparsers.add_parser(
        "doctor",
        help="Check the package installation and wordlist integrity.",
    )
    doctor_parser.set_defaults(function=command_doctor)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.function(args)


if __name__ == "__main__":
    raise SystemExit(main())
